<launch>
  <arg name="config" default="$(find carm_a3_vision)/config/camera.yaml" />
  <arg name="camera_info_url" default="file://$(find carm_a3_vision)/config/camera_info.yaml" />

  <node
    pkg="carm_a3_vision"
    type="v4l2_camera_node"
    name="carm_a3_usb_camera"
    output="screen"
    required="true">
    <rosparam command="load" file="$(arg config)" />
    <param name="camera_info_url" value="$(arg camera_info_url)" />
  </node>
</launch>
